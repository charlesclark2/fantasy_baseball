# =============================================================================
# Environment variable template — copy to .env and fill in real values
# =============================================================================

# Snowflake connection settings
SNOWFLAKE_ACCOUNT=<account>.us-east-2
SNOWFLAKE_USER=dbt_rw
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=ACCOUNTADMIN

# Authentication — use ONE of the two blocks below

# --- Option A: Private key (recommended) -------------------------------------
# Generate with: openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM -out rsa_key.p8 -nocrypt
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8

# --- Option B: Password (fallback, used when PRIVATE_KEY_PATH is not set) ---
# SNOWFLAKE_PASSWORD=<password>

# API KEYS
ODDS_API_KEY=<key>
ODDS_API_STARTER_KEY=<key>
PARLAY_API_KEY=<key>

# AWS Access (used by artifact_store.py to read/write S3 model artifacts)
AWS_ACCESS_KEY_ID=<key>
AWS_SECRET_ACCESS_KEY=<secret>
AWS_DEFAULT_REGION=us-east-2

# MLflow experiment tracking
# Local file-based tracking (default — no server required):
MLFLOW_TRACKING_URI=mlruns
# Artifact store: sub-directory of the project S3 bucket
MLFLOW_ARTIFACT_ROOT=s3://baseball-betting-ml-artifacts/mlflow
