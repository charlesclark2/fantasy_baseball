
# Project-level ignores
.claude/
.user.yml

# Python / notebook artifacts
__pycache__/
*.py[cod]
.ipynb_checkpoints/
*.egg-info/
.env
venv/
.venv/

# Marimo session state (large JSON files with hash strings that trigger GitHub secret scanning)
exploratory_data_analysis/__marimo__/

# Trained model artifacts (large binaries — store via Git LFS or object storage)
betting_ml/models/**/*.pkl

# Daily prediction outputs (written by predict_today.py — tracked in Snowflake, not git)
betting_ml/outputs/predictions*.csv
betting_ml/outputs/probability_outputs*.parquet

# OS
.DS_Store

# Snowflake DDL provisioned copy (contains real secret values — never commit)
scripts/ddl/snowflake_task_dag_provisioned.sql

# Raw data files (large binaries, Excel exports — not tracked in git)
scripts/raw_files/
