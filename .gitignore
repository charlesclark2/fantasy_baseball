
# Project-level ignores
.claude/
.user.yml
idea_notes.md

# Python / notebook artifacts
__pycache__/
*.py[cod]
.ipynb_checkpoints/
*.egg-info/
.env
venv/
.venv/

# Marimo session state (large JSON files with hash strings that trigger GitHub secret scanning)
exploratory_data_analysis/__marimo__/

# Trained model artifacts — all .pkl and .joblib files stored in S3 (baseball-betting-ml-artifacts).
# Artifact paths in model_registry.yaml and sub_model_registry.yaml are S3 URIs.
# To untrack existing committed pkls: git rm --cached betting_ml/models/**/*.pkl
betting_ml/models/**/*.pkl
betting_ml/models/**/*.joblib

# PyMC / ArviZ NUTS trace files (NetCDF4 binary, ~100 MB each — regenerated each inference run)
betting_ml/models/bayesian/*.nc

# Model evaluation artifacts (large binary fold data — regenerated each retrain, not tracked in git)
betting_ml/evaluation/model_evaluation/*.parquet
betting_ml/evaluation/model_evaluation/**/*.parquet

# Training data cache (Parquet snapshots pulled from Snowflake — regenerated on demand)
betting_ml/data/cache/

# Daily prediction outputs (written by predict_today.py — tracked in Snowflake, not git)
betting_ml/outputs/predictions*.csv
betting_ml/outputs/probability_outputs*.parquet

# OS
.DS_Store

# Snowflake DDL provisioned copy (contains real secret values — never commit)
scripts/ddl/snowflake_task_dag_provisioned.sql

# Raw data files (large binaries, Excel exports — not tracked in git)
scripts/raw_files/

# CatBoost training artifacts (auto-generated by catboost, regenerated each run)
catboost_info/

# Runtime log files (empty placeholder files, not useful in git)
logs/

# Duplicate model artifacts directory (canonical copy is betting_ml/models/)
model_artifacts/

# MLflow local tracking store (artifact history stored in S3 under mlflow/ prefix)
mlruns/
mlflow.db

# Training data snapshots (large binary Parquet files — regenerated from Snowflake on demand)
betting_ml/data/*.parquet
betting_ml/data/**/*.parquet

# E5.3 full prop edge/EV table (large, regenerated via edge_devig_props.py; committed: summary+coverage+sample)
quant_sports_intel_models/baseball/edge_program/ablation_results/*.parquet

# E13.13 — bulky SYNTHETIC smoke outputs (regenerate via `eval_derivatives.py --smoke`;
# committed: the small banner-marked _smoke.md proof + the real operator-run dossier, no suffix)
quant_sports_intel_models/baseball/edge_program/ablation_results/e13_13_derivative_efficiency_smoke.json
quant_sports_intel_models/baseball/edge_program/ablation_results/e13_13_market_grid_results_smoke.csv

# Next.js frontend
frontend/.next/
frontend/out/
frontend/node_modules/
frontend/.env.local
frontend/.env*.local
frontend/tsconfig.tsbuildinfo
frontend/.env.sentry-build-plugin
# Layer-3 OOS signal matrices (regenerated from Snowflake on demand)
betting_ml/models/layer3/oos_signals/*.parquet
.lambda_build/
betting_ml/models/sub_models/bullpen_v3/*.parquet

# E11.16 — local dbt State manifest baseline (downloaded by scripts/dbt_state.sh)
dbt/state/

# VAPID / Web Push private keys (E9.9) — never commit
vapid_private.pem
*.pem
