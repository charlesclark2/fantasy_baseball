NEXT_PUBLIC_API_URL=https://api.credencesports.com
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_APP_CLIENT_ID=
# Cognito Hosted-UI domain host (no scheme), e.g. auth.credencesports.com or
# credence-prod.auth.us-east-1.amazoncognito.com. Enables "Continue with Google"
# (E9.7). Leave blank to hide the Google button (password login still works).
NEXT_PUBLIC_COGNITO_HOSTED_UI_DOMAIN=
# Comma-separated admin emails (controls /admin page access and admin API calls)
NEXT_PUBLIC_ADMIN_EMAILS=
