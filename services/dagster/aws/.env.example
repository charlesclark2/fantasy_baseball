# =============================================================================
# INC-16-P1 — env template for the AWS Dagster + dbt-runner + flaresolverr box.
#
#   cp services/dagster/aws/.env.example services/dagster/aws/.env
#   # fill in the values below, then `chmod 600 services/dagster/aws/.env`
#
# Source of truth for the canonical complete set: the current Dagster Cloud →
# Deployment → Environment variables / Secrets export. Reconcile against it.
# .env is gitignored (see services/dagster/aws/.gitignore) — NEVER commit secrets.
#
# A missing var only bites the specific op that reads it; all FanGraphs / weather /
# alert ops are WARN/ALERT-tier, so the morning serving path runs without them —
# but fill them before enabling those sensors in Phase 4.
# =============================================================================

# --- Metadata Postgres (compose-internal; pick any strong password) ----------
DAGSTER_PG_PASSWORD=change-me-strong-random

# --- Snowflake (OLAP / dbt-runner / op queries) ------------------------------
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
# PEM contents (multi-line). entrypoint.sh (dbt-runner) + the Snowflake resource
# write it to /tmp/...pem on boot. In an env_file, keep it on ONE line with \n
# escapes, OR mount it as a file and set SNOWFLAKE_PRIVATE_KEY_PATH instead.
SNOWFLAKE_PRIVATE_KEY=

# --- AWS (S3 lakehouse + serving fallback + dbt state) -----------------------
# PREFERRED: attach an EC2 instance profile (IAM role) with S3 access and LEAVE
# THESE BLANK — boto3 + the S3 VPC endpoint then need no static keys. Set them
# only if you are not using an instance profile.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Sub-model signal scripts (generate_*_signals.py) load their .pkl artifacts from
# S3 only when a cloud-creds signal is present. With an INSTANCE PROFILE there's no
# static AWS_ACCESS_KEY_ID, so set this flag =1 to force S3 loads (the .pkl files are
# gitignored / not in the image). Without it the scripts fall back to a local path
# that doesn't exist → FileNotFoundError. (INC-16-P4 fix.)
ARTIFACTS_FROM_S3=1

# --- dbt-runner ---------------------------------------------------------------
# DBT_RUNNER_URL is set in docker-compose.yml (http://dbt-runner:8080) — do NOT
# set it here. The shared auth token must match on both codeloc and dbt-runner.
DBT_RUNNER_AUTH_TOKEN=
DBT_STATE_BUCKET=baseball-betting-ml-artifacts
DBT_STATE_PREFIX=dbt_state
TARGET_ENV=prod

# --- Serving cache (DynamoDB) — INC-16-P2 ------------------------------------
# The serving cache is DynamoDB now (Railway serving PG decommissioned). DO NOT set
# DATABASE_URL — no serving/capture path references PG anymore. write_serving_store
# reads/writes SERVING_CACHE_TABLE; S3 (CACHE_BUCKET) remains the fallback layer.
SERVING_CACHE_TABLE=credence-prod-serving-cache
CACHE_BUCKET=baseball-betting-ml-artifacts

# --- Odds feeds ---------------------------------------------------------------
ODDS_API_KEY=
ODDS_API_STARTER_KEY=
PARLAY_API_KEY=

# --- Weather ------------------------------------------------------------------
OPENWEATHERMAP_API_KEY=

# --- DynamoDB tables (settle_user_bets_op) -----------------------------------
USER_BETS_TABLE=
USERS_TABLE=

# --- Cognito / email / alerts (alert sensors, narratives) --------------------
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
OWNER_EMAIL=
OWNER_USER_ID=
ADMIN_EMAILS=
SENTRY_DSN=

# --- Optional target db/schema overrides (only if overridden in Dagster+) ----
# ODDS_TARGET_DATABASE=
# ODDS_TARGET_SCHEMA=
# SAVANT_TARGET_DATABASE=
# SAVANT_TARGET_SCHEMA=
# PARLAY_TARGET_DATABASE=
# PARLAY_TARGET_SCHEMA=

# NOTE: FLARESOLVERR_URL is set in docker-compose.yml (http://flaresolverr:8191/v1)
# — do NOT set it here.

# --- dagit HTTPS + basic-auth (Caddy) — INC-16-P4 ----------------------------
# Caddy serves dagit at https://${DAGIT_HOSTNAME} behind basic-auth. The hash goes
# here AS-IS (Caddy reads it from the container env via {$VAR}; compose does not
# interpolate env_file values, so the `$` in the bcrypt hash is safe — no escaping).
#   generate the hash:  docker run --rm caddy:2 caddy hash-password --plaintext 'YOUR_PASSWORD'
DAGIT_HOSTNAME=dagster.credencesports.com
DAGIT_BASIC_AUTH_USER=
DAGIT_BASIC_AUTH_HASH=
